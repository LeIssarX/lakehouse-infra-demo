# ==========================================================
# Development Environment Variables (EXAMPLE)
# ==========================================================
# INSTRUCTIONS (new project):
# 1. Copy this file to dev.tfvars:
#    cp infra/envs/dev/dev.tfvars.example infra/envs/dev/dev.tfvars
# 2. Review and customize values for your dev environment
# 3. Commit dev.tfvars to Git (tfvars are versioned for team collaboration)
# Usage: see infra/CLAUDE.md.
# ==========================================================

# ==========================================================
# Environment Identification
# ==========================================================

environment     = "dev"
subscription_id = "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX" # FIXME: Your Azure Subscription ID

# Bootstrap mode: set to true only for the very first apply in a greenfield environment.
# After initial deployment completes, set back to false (or remove the line entirely).
bootstrap_mode = false

# ==========================================================
# Resource Naming
# ==========================================================

resource_group_name       = "rg-lakehouse-dev"
databricks_workspace_name = "dbw-lakehouse-dev"
catalog_name              = "lakehouse_dev"
storage_account_prefix    = "dlhdev" # Random suffix auto-appended

# LOCAL DEV AUTH: Set this to your workspace URL after the first deployment.
# This allows tofu-wrapper.sh to use a PAT profile (aschwabe-dev) locally
# without conflicting with the CI/CD ARM-based azure_workspace_resource_id auth.
# Leave null or omit in CI/CD — the workspace URL is derived automatically.
# databricks_workspace_url = "https://adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net" # FIXME: your dev workspace URL

# ==========================================================
# Unity Catalog Metastore Configuration
# ==========================================================

# Option 1: Use auto-provisioned metastore (recommended for new workspaces)
unity_catalog_metastore_mode = "auto"
unity_catalog_metastore_id   = null

# Option 2: Use existing metastore (if you have account limits or want to share)
# unity_catalog_metastore_mode = "existing"
# unity_catalog_metastore_id   = "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX" # FIXME: Your metastore ID

# ==========================================================
# Observability
# ==========================================================

log_retention_days = 30 # Dev: 30 days (cost optimization)

# ==========================================================
# Network Configuration
# ==========================================================

# Dev uses simplified setup without VNet injection
enable_vnet_injection = false
enable_public_access  = true

# ==========================================================
# Network & Private Endpoint (optional)
# ==========================================================

# Private endpoint (disabled in dev — requires enable_vnet_injection = true)
enable_private_endpoint = false

# VNet settings (only used if enable_vnet_injection = true)
vnet_name          = "vnet-lakehouse-dev"
vnet_address_space = ["10.100.0.0/16"]

# Subnet prefixes (inherited from common.tfvars, override if needed)
# public_subnet_address_prefixes  = ["10.100.1.0/24"]
# private_subnet_address_prefixes = ["10.100.2.0/24"]

# ==========================================================
# Storage Accounts (ADLS Gen2)
# ==========================================================
# Provisions one Azure Data Lake Storage Gen2 account per entry.
# Account name: "{storage_account_prefix}{key}{random}" (max 24 chars total).
#
# The "lake" key is REQUIRED — it serves as the Unity Catalog Metastore root.
# All containers in all accounts are automatically registered as Unity Catalog
# External Locations (key pattern: "{account}-{container}", e.g. "lake-raw").
#
# Add further entries for domain separation (PII isolation) or billing isolation.
#
# Available fields:
#   containers               (optional) - List of ADLS containers to create.
#                                         Default: all 8 standard lakehouse containers.
#                                         Standard containers: metastore, landing, raw,
#                                         curated, core, mart, reporting, sharing
#   account_tier             (optional) - Storage tier. Default: "Standard"
#                                         Options: Standard | Premium (high IOPS workloads)
#   replication_type         (optional) - Azure replication strategy. Default: "LRS"
#                                         Options: LRS  (local, cheapest — fine for dev)
#                                                  ZRS  (zone-redundant, dev/staging)
#                                                  GRS  (geo-redundant, recommended prod)
#                                                  GZRS (geo + zone-redundant, max resilience)
#   enable_lifecycle_policy  (optional) - Auto-tier blobs Hot → Cool → Archive. Default: false
#   lifecycle_containers     (optional) - Which containers to apply lifecycle to. Default: ["raw"]
#   cool_after_days          (optional) - Move to Cool tier after N days. Default: 30
#   archive_after_days       (optional) - Move to Archive tier after N days. Default: 90
#   delete_after_days        (optional) - Delete blobs after N days. Default: 365 (0 = never)
#   enable_soft_delete       (optional) - Enable blob soft delete (recovery window). Default: true
#   soft_delete_retention_days (optional) - Soft delete retention in days. Default: 7

storage_accounts = {
  "lake" = {
    containers       = ["metastore", "landing", "raw", "curated", "core", "mart", "reporting", "sharing"]
    replication_type = "LRS" # Dev: local redundancy is sufficient
  }
  # Add a second account for domain separation or billing isolation:
  # "secure" = {
  #   containers = ["pii", "restricted"]
  #   replication_type = "ZRS"
  # }
}

# ==========================================================
# Security Configuration
# ==========================================================

# Key Vault name (optional — auto-generated if omitted)
# key_vault_name = "kv-lakehouse-dev"

# Key Vault firewall (empty = open access with RBAC)
key_vault_allowed_ips = []

# IP Access Lists (disabled in dev for ease of access)
enable_ip_access_lists = false
governance_allowed_ips = []

# ==========================================================
# Environment-Specific Tags
# ==========================================================

# These tags are merged with common.tfvars base tags
tags = {
  "Environment" = "dev"
  "Purpose"     = "Development and Testing"
}

# ==========================================================
# Compute: Interactive Clusters
# ==========================================================
# Provisions one Databricks interactive cluster per entry.
# Cluster name: "{environment}-{key}" (e.g. "dev-engineering").
#
# Add an entry to provision a cluster; remove it to deprovision.
# Dev: self-service clusters per user or team. Prod: keep clusters = {}.
#
# Available fields:
#   owner                    (required) - User email set as single-user cluster owner.
#                                         Must be a workspace member.
#   node_type                (optional) - Azure VM size. Default: "Standard_DS4_v2"
#                                         Options: Standard_DS3_v2  (4 vCPU, 14 GB, cost-efficient)
#                                                  Standard_DS4_v2  (8 vCPU, 28 GB, default)
#                                                  Standard_E8_v3   (8 vCPU, 64 GB, memory-optimized)
#                                                  Standard_E16_v3  (16 vCPU, 128 GB, ML workloads)
#   min_workers              (optional) - Minimum autoscale workers. Default: 1
#   max_workers              (optional) - Maximum autoscale workers. Default: 4
#   spark_version            (optional) - Databricks Runtime version. Default: "auto:latest-lts"
#                                         Options: "auto:latest-lts"  (recommended — always current LTS)
#                                                  "auto:latest-ml"   (ML runtime with MLflow, sklearn)
#                                                  "15.4.x-scala2.12" (pin to specific version)
#   data_security_mode       (optional) - Unity Catalog security mode. Default: "SINGLE_USER"
#                                         Options: SINGLE_USER   (required for Row-Level Security)
#                                                  USER_ISOLATION (shared cluster, no RLS)
#   policy_key               (optional) - Governance policy to attach. Default: "shared_interactive"
#                                         Options: shared_interactive  (dev exploration, autoscaling)
#                                                  ml_clusters         (ML runtimes, GPU-ready)
#                                                  job_clusters        (batch workloads)
#                                                  lakeflow_pipelines  (streaming, Photon-enabled)
#   enable_spot              (optional) - Use Azure Spot instances for cost savings. Default: true
#                                         Set to false in prod for higher availability.
#   auto_termination_minutes (optional) - Auto-stop idle cluster after N minutes. Default: 30
#                                         Min: 10. Use higher values for long-running notebooks.

clusters = {
  # "engineering" = {
  #   owner = "your.email@company.com"  # FIXME: set to workspace member email
  # }
  # "ml" = {
  #   owner      = "ml-lead@company.com"  # FIXME
  #   node_type  = "Standard_E8_v3"
  #   policy_key = "ml_clusters"
  # }
}

# Cluster policy limit: dev users can run more clusters concurrently
interactive_max_clusters_per_user = 5 # Relaxed limit for dev self-service

# Unity Catalog user isolation — override common.tfvars if needed
# enforce_user_isolation = true  # default: true

# MLflow auto-logging — override common.tfvars if needed
# enable_ml_autologging = false  # default: false

# ==========================================================
# Compute: SQL Warehouses
# ==========================================================
# Provisions one Databricks SQL Warehouse per entry.
# Warehouse name: "{environment}-{key}" (e.g. "dev-shared").
#
# SQL Warehouses serve SQL queries, BI tools, and AI/BI dashboards.
# Use separate warehouses per team or workload to isolate cost and performance.
#
# Available fields:
#   size              (optional) - Cluster size controlling query throughput. Default: "Small"
#                                  Options (DBU/h per cluster):
#                                    "X-Small" (1),  "Small" (2),   "Medium" (4),
#                                    "Large" (8),    "X-Large" (16), "2X-Large" (32),
#                                    "3X-Large" (64), "4X-Large" (128)
#   type              (optional) - Warehouse type. Default: "PRO"
#                                  Options: PRO     (AI/BI, Genie, serverless — recommended)
#                                           CLASSIC (legacy SQL analytics only)
#   auto_stop_mins    (optional) - Stop idle warehouse after N minutes. Default: 30
#                                  Set to 0 to disable auto-stop (not recommended).
#   enable_serverless (optional) - Use serverless compute for instant cold start. Default: true
#                                  Requires serverless enabled in the Databricks workspace.

sql_warehouses = {
  # "shared" = {}  # All defaults: Small, PRO, serverless, auto-stop 30 min
  # "analytics" = {
  #   size           = "Medium"
  #   auto_stop_mins = 15
  # }
}

# ==========================================================
# CI/CD Configuration
# ==========================================================

# GitHub Actions Service Principal
# Uncomment and set to your AZURE_CLIENT_ID GitHub secret value
# cicd_sp_application_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ==========================================================
# Workload Service Principal (OPTIONAL FOR DEV)
# ==========================================================

# Workload SPs are typically not needed for dev (use your user identity)
# Uncomment below if you want to test the production workload SP flow in dev

# enable_workload_sp = true
# workload_sp_name   = "Lakehouse Pipeline (dev)"
#
# workload_sp_catalog_grants = {
#   "lakehouse_dev" = ["USE CATALOG"]
# }
#
# workload_sp_schema_grants = {
#   "lakehouse_dev.raw"     = ["USE SCHEMA", "SELECT"]
#   "lakehouse_dev.curated" = ["USE SCHEMA", "SELECT", "MODIFY"]
#   "lakehouse_dev.mart"    = ["USE SCHEMA", "SELECT", "MODIFY"]
# }

# ==========================================================
# Unity Catalog Grants (Benutzergruppen)
# ==========================================================
# Grants for Azure AD groups synced via AIM module.
# Catalog-level ALL_PRIVILEGES for Admins cascades to all schemas automatically.
# All other roles get USE_CATALOG only at catalog level — actual data access
# is granted at schema level (least-privilege principle).

catalog_grants = {
  admins    = { principal = "Databricks-Admins-Dev",    privileges = ["ALL_PRIVILEGES"] }
  engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_CATALOG"] }
  analysts  = { principal = "Databricks-Analysts-Dev",  privileges = ["USE_CATALOG"] }
  stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_CATALOG", "APPLY_TAG"] }
  users     = { principal = "Databricks-Users-Dev",     privileges = ["USE_CATALOG"] }
}

schema_grants = {
  landing = {
    # Engineers own ingestion — full write access to landing zone
    engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_SCHEMA", "CREATE_TABLE", "CREATE_VOLUME", "SELECT", "MODIFY", "READ_VOLUME", "WRITE_VOLUME"] }
    # Stewards need to see incoming data for PII identification
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
  }
  raw = {
    # Engineers write raw data, Stewards read for governance
    engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_SCHEMA", "CREATE_TABLE", "CREATE_VOLUME", "SELECT", "MODIFY", "READ_VOLUME", "WRITE_VOLUME"] }
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
  }
  curated = {
    engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_SCHEMA", "CREATE_TABLE", "SELECT", "MODIFY"] }
    analysts  = { principal = "Databricks-Analysts-Dev",  privileges = ["USE_SCHEMA", "SELECT"] }
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
  }
  core = {
    engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_SCHEMA", "CREATE_TABLE", "SELECT", "MODIFY"] }
    analysts  = { principal = "Databricks-Analysts-Dev",  privileges = ["USE_SCHEMA", "SELECT"] }
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
  }
  mart = {
    # Dev: Engineers can still write mart (self-service development)
    engineers = { principal = "Databricks-Engineers-Dev", privileges = ["USE_SCHEMA", "CREATE_TABLE", "SELECT", "MODIFY"] }
    analysts  = { principal = "Databricks-Analysts-Dev",  privileges = ["USE_SCHEMA", "SELECT"] }
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
    users     = { principal = "Databricks-Users-Dev",     privileges = ["USE_SCHEMA", "SELECT"] }
  }
  reporting = {
    analysts  = { principal = "Databricks-Analysts-Dev",  privileges = ["USE_SCHEMA", "CREATE_TABLE", "SELECT", "MODIFY"] }
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "SELECT", "APPLY_TAG"] }
    users     = { principal = "Databricks-Users-Dev",     privileges = ["USE_SCHEMA", "SELECT"] }
  }
  sharing = {
    stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["USE_SCHEMA", "CREATE_TABLE", "SELECT", "MODIFY", "APPLY_TAG"] }
  }
}

# ==========================================================
# System Schema Grants (Unity Catalog system tables)
# ==========================================================
# Optional: Grant SELECT on system schemas to stewards/engineers for observability.
# System schemas are enabled automatically (enable_system_tables = true in main.tf).
# Uncomment to grant access:

# system_schema_grants = {
#   access  = { stewards = { principal = "Databricks-Stewards-Dev", privileges = ["SELECT"] } }
#   billing = { stewards = { principal = "Databricks-Stewards-Dev", privileges = ["SELECT"] } }
#   lineage = { stewards = { principal = "Databricks-Stewards-Dev", privileges = ["SELECT"] } }
#   query   = {
#     stewards  = { principal = "Databricks-Stewards-Dev",  privileges = ["SELECT"] }
#     engineers = { principal = "Databricks-Engineers-Dev", privileges = ["SELECT"] }
#   }
# }

# ==========================================================
# NOTES
# ==========================================================
#
# 1. This file contains ONLY environment-specific values
#    Global configuration is in infra/common.tfvars
#
# 4. dev_remote_state_* variables are intentionally absent here.
#    They are only needed in prod.tfvars to read dev's shared
#    metastore ID via OpenTofu remote state.
#
# 2. Keep dev configuration simple:
#    - No VNet injection
#    - Open Key Vault access
#    - Lower cost resources
#    - Faster iteration
#
# 3. Changes to this file affect only DEV environment
#
# ==========================================================
